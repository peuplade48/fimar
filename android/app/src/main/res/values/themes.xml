<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- FİMAR Ana Tema -->
    <style name="Theme.Fimar" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/accent_cyan</item>

        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark2</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Metin -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- SplashScreen (API 31+) -->
    <style name="Theme.Fimar.Splash" parent="Theme.Fimar">
        <item name="android:windowSplashScreenBackground">@color/bg_dark</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
    </style>
</resources>
